APP_NAME=Student Retention AI Platform
APP_ENV=production
API_V1_STR=/api/v1
APP_BASE_PATH=/Retention-AI
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=120
DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:3306/student_retention
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DB=student_retention
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Retention AI
CLIENT_URL=https://your-frontend-domain.vercel.app
CORS_ORIGINS=https://your-frontend-domain.vercel.app
ALLOWED_HOSTS=your-backend-domain.onrender.com
FORCE_HTTPS=True
MODEL_DIR=backend/models

# Use DATABASE_URL in production. Keep the real value in Render environment variables.
